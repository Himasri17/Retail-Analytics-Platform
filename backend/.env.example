# Copy this file to .env and adjust as needed.

# Default: local SQLite file (zero setup, works out of the box)
DATABASE_URL=sqlite:///./superstore.db

# To use PostgreSQL instead, comment the line above and uncomment/edit below:
# DATABASE_URL=postgresql+psycopg2://postgres:password@localhost:5432/superstore_db

# Path to the source CSV used by load_data.py
CSV_PATH=../data/superstore.csv

# Allowed CORS origin for the React dev server
FRONTEND_ORIGIN=http://localhost:5173
